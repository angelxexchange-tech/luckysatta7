<section class="blog_main_section bg-white pb-10">
    <div class="blog_top_heading">
        <a href="/blogs" class="text-white hover:underline text-sm md:text-base">← BACK TO ALL BLOGS</a>
    </div>
    <div class="container mx-auto px-4 mt-6">
        <div class="bg-white rounded-xl shadow-lg border-2 border-orange-200 overflow-hidden max-w-4xl mx-auto">
            <div class="w-full h-64 md:h-96 relative bg-gray-100">
                <img src="<%= blog.image %>" alt="<%= blog.title %>" class="w-full h-full object-contain">
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex flex-col justify-end p-6 md:p-10 text-white">
                    <p class="text-xs md:text-sm font-semibold text-blue-300 mb-2 uppercase tracking-wider"><%= blog.tags %></p>
                    <h1 class="text-2xl md:text-4xl font-bold leading-tight mb-2"><%= blog.title %></h1>
                    <p class="text-sm text-gray-300"><%= blog.date %></p>
                </div>
            </div>
            <div class="p-6 md:p-10 text-gray-800 leading-relaxed space-y-6 text-lg">
                <%- blog.content %>
            </div>
        </div>
    </div>
</section>

