

    <!-- Main Card -->
    <div class="w-full max-w-7xl   bg-[#171d4d] p-5">

        <!-- Header -->
        <div class="flex items-center gap-3 mb-6">
            <div
                class="w-10 h-10 rounded-lg bg-[#2c3566] flex items-center justify-center text-xl">
                🔢
            </div>

            <h2 class="text-[#1ff07a] text-2xl font-bold leading-tight">
                Most Frequent Numbers <%= typeof game !== 'undefined' && game ? ' - ' + game.toUpperCase() : '' %>
            </h2>
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-3 lg:grid-cols-6 gap-3">
            <% if (typeof frequentNumbers !== 'undefined' && frequentNumbers.length > 0) { %>
                <% frequentNumbers.forEach(item => { %>
                    <div class="h-[88px] rounded-lg border border-[#18d26b] bg-[#123631] flex flex-col items-center justify-center">
                        <span class="text-[#1ff07a] text-[28px] font-bold"><%= item.number %></span>
                        <span class="text-slate-400 text-xs mt-2"><%= item.count %> <%= item.count === 1 ? 'time' : 'times' %></span>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-3 lg:col-span-6 text-center text-slate-400 py-4">No data available for this month.</div>
            <% } %>
        </div>

    </div>
