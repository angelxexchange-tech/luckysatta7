<!DOCTYPE html>
<html lang="en-IN">

<head>
    <meta charSet="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <% if (locals.seo && locals.seo.metaDescription) { %>
    <meta name="description" content="<%= locals.seo.metaDescription %>" />
    <% } else { %>
    <meta name="description" content="lucky-satta7 results with updated charts, historical records, and fast daily updates. Check Delhi, Faridabad, and Disawar results online." />
    <% } %>
    
    <% if (locals.seo && locals.seo.focusKeywords && locals.seo.focusKeywords.length > 0) { %>
    <meta name="keywords" content="<%= locals.seo.focusKeywords.join(', ') %>" />
    <% } else { %>
    <meta name="keywords" content="lucky-satta7 – Live Satta Result Today & Chart 2026 " />
    <% } %>

    <% if (locals.seo && locals.seo.metaTitle) { %>
    <title><%= locals.seo.metaTitle %></title>
    <% } else { %>
    <title>lucky-satta7 – LIVE SATTA RESULT TODAY & CHART 2026 </title>
    <% } %>

    <link rel="shortcut icon" type="image/png" href="/7Favicon.png">
    
    <% if (locals.seo && locals.seo.canonical) { %>
    <link rel="canonical" href="<%= locals.seo.canonical %>" />
    <% } %>
    
    <% if (locals.seo && locals.seo.robots) { %>
    <meta name="robots" content="<%= locals.seo.robots %>" />
    <% } %>
    
    <% if (locals.seo && locals.seo.author) { %>
    <meta name="author" content="<%= locals.seo.author %>" />
    <% } %>

    <% if (locals.seo && locals.seo.publisher) { %>
    <meta name="publisher" content="<%= locals.seo.publisher %>" />
    <% } %>

    <meta property="og:title" content="lucky-satta7official website" />
    <meta property="og:site_name" content="lucky-satta7official website" />
    <meta property="og:locale" content="en_IN" />
    
    <meta property="og:type" content="website" />
    <meta property="og:description" content="lucky-satta7 results with updated charts, historical records, and fast daily updates. Check Delhi, Faridabad, and Disawar results online." />
    <meta property="og:image" content="/7Favicon.png" />
    
    <link rel="icon" type="favicon" href="7Favicon.png" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    animation: {
                        'blink-glow': 'blinkGlow 1s infinite',
                        'blink': 'blink 1s infinite',
                        'blink-black': 'blinkBlack 1s infinite',
                    },
                    keyframes: {
                        blinkGlow: {
                            '0%, 100%': { opacity: '1', textShadow: '0 0 5px #fff, 0 0 10px #ff4da6, 0 0 20px #3b82f6' },
                            '50%': { opacity: '0.5', textShadow: 'none' },
                        },
                        blink: {
                            '0%, 100%': { opacity: '1' },
                            '50%': { opacity: '0.3' },
                        },
                        blinkBlack: {
                            '0%, 100%': { opacity: '1' },
                            '50%': { opacity: '0.3' },
                        }
                    },
                    fontFamily: {
                        Roboto: ['Roboto', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <script>
        setInterval(function () {
            let now = new Date();
            let options = {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
            };
            let date = now.toLocaleDateString('en-US', options);
            let time = now.toLocaleTimeString('en-US');
            document.getElementById("timerBox").innerText = date + " " + time;
        }, 1000);
    </script>
    
    
    
</head>

<body class="max-w-7xl mx-auto font-Roboto">
    <div id="__next">
        <%- include('./partials/header') %>

            <%- body %>
    </div>
</body>

</html>