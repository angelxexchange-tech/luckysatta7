            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            margin-right: 1.5rem;
        }
        .ticker-name {
            font-weight: 700;
        }
        .ticker-result,
        .ticker-time {
            font-weight: 700;
        }
        .ticker-sep {
            display: inline-block;
