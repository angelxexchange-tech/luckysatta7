            <!-- 4 Games Cards Row -->
            <%
                const findGame = (name) => {
                    return (gr1Games || []).find(g => g.name && g.name.toLowerCase().trim() === name.toLowerCase().trim()) || null;
                };
                const waitingSpinner = '<div class="waiting-box"><div class="waiting-dots"><span class="dot dot1"></span><span class="dot dot2"></span><span class="dot dot3"></span></div><span class="waiting-text">Waiting...</span></div>';
                const getResult = (game) => {
                    if (!game) return waitingSpinner;
                    if (game.todayNumber && game.todayNumber.value) return game.todayNumber.value;
                    return waitingSpinner;
                };
                const getPrevResult = (game) => {
                    if (!game) return waitingSpinner;
                    if (game.yesterdayNumber && game.yesterdayNumber.value) {
                        return game.yesterdayNumber.value;
                    }
                    return waitingSpinner;
                };
                const getTime = (game, defaultTime) => {
                    return (game && game.resultTime12h) ? game.resultTime12h : defaultTime;
                };
                const getChartUrl = (game) => {
                    if (!game || !game.name) return "#";
                    return "/chart-2026/" + game.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '') + "-satta-result";
                };
            %>
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-2 md:gap-4 p-2 md:p-4 w-full">
                <% if (gr1Games && gr1Games.length > 0) { %>
                    <% 
                        const hindiNames = {
                            "faridabad": "फ़रीदाबाद",
                            "paisa bazaar": "पैसा बाज़ार",
                            "shree ganesh": "श्री गणेश",
                            "shri ganesh": "श्री गणेश",
                            "delhi bazaar": "दिल्ली बाज़ार",
                            "delhibazar": "दिल्ली बाज़ार",
                            "gali": "गली",
                            "disawar": "दिसावर",
                            "dishawer": "दिसावर",
                            "delhi state": "दिल्ली स्टेट",
                            "pune city": "पुणे सिटी",
                            "kalyan": "कल्याण",
                            "mumbai": "मुंबई",
                            "city bazaar": "सिटी बाज़ार",
                            "navi mumbai": "नवी मुंबई",
                            "delhi king": "दिल्ली किंग",
                            "ajmer sharif": "अजमेर शरीफ",
                            "ayodya nagari": "अयोध्या नगरी",
                            "bhagya rekha": "भाग्य रेखा",
                            "bitcoin": "बिटकॉइन",
                            "chandigarh city": "चंडीगढ़ सिटी",
                            "cyber city": "साइबर सिटी",
                            "dhaula kuan": "धौला कुआँ",
                            "ghanta ghar": "घंटा घर",
                            "ghaziabad": "गाज़ियाबाद",
                            "golden city": "गोल्डन सिटी",
                            "g-town": "जी-टाउन",
                            "jai bheem": "जय भीम",
                            "jamuna paar": "जमुना पार",
                            "kalyan king": "कल्याण किंग",
                            "maa ganga": "माँ गंगा",
                            "miraz": "मिराज़",
                            "sadar bazaar": "सदर बाज़ार",
                            "sector 17": "सेक्टर 17",
                            "subh labh": "शुभ लाभ"
                        };
                        const getHindiName = (name) => {
                            if (!name) return "";
                            const n = name.replace(/\s+/g, ' ').trim().toLowerCase();
                            return hindiNames[n] ? hindiNames[n] : "";
                        };

                        const now = new Date();
                        const istTime = new Date(now.toLocaleString("en-US", {timeZone: "Asia/Kolkata"}));
                        const currentMins = istTime.getHours() * 60 + istTime.getMinutes();

                        const getMins = (timeStr) => {
                            if (!timeStr) return 24 * 60;
                            const value = timeStr.toString().trim();
                            const ampmMatch = value.match(/^(\d{1,2}):(\d{2})\s*(AM|PM)$/i);
                            if (ampmMatch) {
                                let hours = Number(ampmMatch[1]);
                                const minutes = Number(ampmMatch[2]);
                                const ampm = ampmMatch[3].toUpperCase();
                                if (hours === 12) {
                                    hours = (ampm === 'AM') ? 0 : 12;
                                } else if (ampm === 'PM') {
                                    hours += 12;
                                }
                                return hours * 60 + minutes;
                            }
                            const [h, m] = value.split(':').map(Number);
                            if (Number.isFinite(h) && Number.isFinite(m)) {
                                return h * 60 + m;
                            }
                            return 24 * 60;
                        };

                        const declaredGames = gr1Games.filter(g => g.todayNumber && g.todayNumber.value);
                        const upcomingGames = gr1Games.filter(g => !(g.todayNumber && g.todayNumber.value));

                        const sortByResultTime = (games) => {
                            return games.slice().sort((a, b) => {
                                let aMins = getMins(a.resultTime);
                                let bMins = getMins(b.resultTime);
                                return aMins - bMins;
                            });
                        };

                        const getRelativePastMins = (game) => {
                            const mins = getMins(game.resultTime);
                            let diff = currentMins - mins;
                            if (diff < 0) diff += 24 * 60;
                            return diff;
                        };

                        const sortedUpcoming = upcomingGames.slice().sort((a, b) => {
                            let aMins = getMins(a.resultTime);
                            let bMins = getMins(b.resultTime);
                            if (aMins < currentMins - 60) aMins += 24 * 60;
                            if (bMins < currentMins - 60) bMins += 24 * 60;
                            return aMins - bMins;
                        });

                        const sortedPast = declaredGames.slice().sort((a, b) => {
                            return getRelativePastMins(a) - getRelativePastMins(b);
                        });

                        let displayGames = [];
                        if (sortedUpcoming.length > 0) {
                            displayGames.push(sortedUpcoming[0]);
                        }

                        let pastIndex = 0;
                        while (displayGames.length < 4 && pastIndex < sortedPast.length) {
                            displayGames.push(sortedPast[pastIndex]);
                            pastIndex += 1;
                        }

                        if (displayGames.length < 4) {
                            const fillGames = gr1Games.filter(g => !displayGames.includes(g));
                            const fillPast = fillGames.filter(g => g.todayNumber && g.todayNumber.value);
                            const fillSorted = sortByResultTime(fillPast.length > 0 ? fillPast : fillGames);
                            while (displayGames.length < 4 && fillSorted.length > 0) {
                                displayGames.push(fillSorted.shift());
                            }
                        }
                    %>
                    <% displayGames.slice(0, 4).forEach(game => { %>
                        <div class="bg-white flex flex-col text-center rounded-[3px] overflow-hidden shadow-md">
                            <div class="text-white py-[8px] bg-gradient-to-br from-blue-400 to-pink-700">
                                <div class="text-[1.2rem] font-medium leading-tight tracking-wide"><%= (game.name || "").toUpperCase() %></div>
                                <% const hName = getHindiName(game.name); if(hName) { %>
                                    <div class="text-[0.9rem] font-medium leading-tight"><%= hName %></div>
                                <% } %>
                            </div>
                            <div class="pt-[22px] pb-[16px] flex-grow bg-white">
                                <div class="text-[3.2rem] font-normal leading-none mb-[12px]" style="color: #3b4255;"><%- getResult(game) %></div>
                                <div class="text-[14px] font-medium" style="color: #28a745;"><%= getTime(game, "Time TBA") %></div>
                            </div>
                            <div class="pb-[14px] bg-white flex flex-col gap-[3px]" style="color: #337ab7;">
                                <a href="<%= getChartUrl(game) %>" class="hover:underline text-[13px]">पिछला रिजल्ट <%- getPrevResult(game) %></a>
                                <a href="<%= getChartUrl(game) %>" class="hover:underline text-[13px]">Record Chart</a>
                                <a href="/mostfrequent" class="hover:underline text-[12px] mt-[2px]" style="color: #4a90e2;">Extended chart on SattaFree &rarr;</a>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-span-2 lg:col-span-4 text-center py-4 text-gray-500">No games available</div>
                <% } %>
