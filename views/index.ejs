            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            vertical-align: middle;
        }
        /* FAQ Container */
        .faq_block {
            padding: 20px 0;
        }

        /* Each item */
        .faq_item {
            border: 1px solid #ddd;
            border-radius: 10px;
            margin-bottom: 12px;
            overflow: hidden;
            background: #fff;
            transition: all 0.3s ease;
        }

        /* Question */
        .faq_question {
            padding: 15px 20px;
            font-weight: 600;
            cursor: pointer;
            position: relative;
            background: #f5f7fa;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Hover */
        .faq_question:hover {
            background: #e9eef5;
        }

        /* Toggle (+ / -) */
        .faq_toggle {
            font-size: 20px;
            font-weight: bold;
            transition: transform 0.3s ease;
        }

        /* Answer (hidden by default) */
        .faq_answer {
            max-height: 0;
            overflow: hidden;
            padding: 0 20px;
            background: #fff;
            transition: all 0.4s ease;
        }

        /* Active state */
        .faq_item.active .faq_answer {
            max-height: 300px;
            /* adjust if content bigger */
            padding: 15px 20px;
        }

        /* Rotate + to - */
        .faq_item.active .faq_toggle {
            transform: rotate(45deg);
        }

        .faq_item {
            background: linear-gradient(to right, #ffffff, #f8fafc);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
