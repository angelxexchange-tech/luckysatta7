    <style>
        /* ===== Waiting Indicator Styles ===== */
        @keyframes dotPulse {
            0%, 80%, 100% { transform: scale(0.4); opacity: 0.3; }
            40% { transform: scale(1); opacity: 1; }
        }
        @keyframes shimmer {
            0% { background-position: -200% center; }
            100% { background-position: 200% center; }
        }
        .waiting-box {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 8px 0;
        }
        .waiting-box-sm {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 3px;
            padding: 2px 0;
        }
        .waiting-dots {
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .waiting-dots .dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: linear-gradient(135deg, #e53e3e, #f56565);
            animation: dotPulse 1.4s ease-in-out infinite;
            box-shadow: 0 0 6px rgba(229, 62, 62, 0.4);
        }
        .waiting-box-sm .waiting-dots .dot {
            width: 7px;
            height: 7px;
            box-shadow: 0 0 4px rgba(229, 62, 62, 0.3);
        }
        .waiting-dots .dot1 { animation-delay: 0s; }
        .waiting-dots .dot2 { animation-delay: 0.2s; }
        .waiting-dots .dot3 { animation-delay: 0.4s; }
        .waiting-text {
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            background: linear-gradient(90deg, #b91c1c, #ef4444, #f97316, #ef4444, #b91c1c);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmer 2.5s linear infinite;
        }
        .waiting-text-sm {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            background: linear-gradient(90deg, #b91c1c, #ef4444, #f97316, #ef4444, #b91c1c);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmer 2.5s linear infinite;
        }
