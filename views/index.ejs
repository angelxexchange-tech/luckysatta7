
    <div id="__next">
        <div>
            <div class="max-w-screen-xl px-4 mx-auto md:px-6">
                <h1 class="text-lg font-bold text-center text-gray-900 uppercase">Welcome to
                    <!-- -->lucky-satta7official website
                </h1>
            </div>
                <% 
                   const allowedGames = ["delhi bazaar", "shree ganesh", "shri ganesh", "faridabad", "gali", "disawar", "dishawer", "delhibazar"];
                   let validCards = (upcomingCards || []).filter(c => {
                       const name = (c.name || "").trim().toLowerCase();
                       const strictName = name.replace(/\s+/g, '');
                       return allowedGames.includes(name) || allowedGames.includes(strictName);
                   });
                   
                   if (validCards.length === 0 && upcomingCards && upcomingCards.length > 0) {
                       validCards = upcomingCards;
                   }

                   let filteredCards = validCards.filter(c => {
                       if (!c.latestResult) return true; // It's upcoming, show it
                       
                       if (c.resultTime) {
                           const [hours, minutes] = c.resultTime.split(':').map(Number);
                           const now = new Date();
                           // Convert now to IST to match resultTime
                           const istTime = new Date(now.toLocaleString("en-US", {timeZone: "Asia/Kolkata"}));
                           let resultDate = new Date(istTime);
                           resultDate.setHours(hours, minutes, 0, 0);
                           
                           // Handle overnight wraps
                           if (istTime.getTime() < resultDate.getTime() && hours > 12 && istTime.getHours() < 12) {
                               resultDate.setDate(resultDate.getDate() - 1);
                           }
                           
                           const diffMins = (istTime.getTime() - resultDate.getTime()) / 60000;
                           return diffMins >= 0 && diffMins <= 25; // Show if within 25 minutes
                       }
                       return false;
                   });

                   // Fallback so the box isn't empty: show NEXT upcoming allowed game
                   if (filteredCards.length === 0) {
                       let allowedAllGames = (typeof allGames !== 'undefined' ? allGames : []).filter(g => {
                           const name = (g.name || "").trim().toLowerCase();
                           const strictName = name.replace(/\s+/g, '');
                           return allowedGames.includes(name) || allowedGames.includes(strictName);
                       });

                       const fallbackNow = new Date();
                       const fallbackIstTime = new Date(fallbackNow.toLocaleString("en-US", {timeZone: "Asia/Kolkata"}));
                       const currentMins = fallbackIstTime.getHours() * 60 + fallbackIstTime.getMinutes();
                       let nextUpcomingGame = null;
                       let minDiff = Infinity;

                       allowedAllGames.forEach(g => {
                           if (g.resultTime) {
                               const [h, m] = g.resultTime.split(':').map(Number);
                               const gameMins = h * 60 + m;
                               let diff = gameMins - currentMins;
                               if (diff <= 0) {
                                   diff += 24 * 60; // if it already passed today, it's next tomorrow
                               }
                               // Ignore games that just passed within 40 mins because they would already be in filteredCards if they were returned by the API
                               if (diff < minDiff && diff > 40) {
                                   minDiff = diff;
                                   nextUpcomingGame = g;
                               }
                           }
                       });

                       if (nextUpcomingGame) {
                           filteredCards = [{
                               name: nextUpcomingGame.name,
                               latestResult: null, // Force upcoming spinner
                               resultTime: nextUpcomingGame.resultTime
                           }];
                       }
                   }
                %>
                <% 
                   const tickerCards = (gr1Games && gr1Games.length > 0) ? gr1Games : ((validCards && validCards.length > 0) ? validCards : (upcomingCards || []));
                   const parseMins = (timeStr) => {
                       if (!timeStr) return 24 * 60;
                       const normalized = timeStr.toString().trim().toUpperCase();
                       const ampmMatch = normalized.match(/(AM|PM)$/);
                       if (ampmMatch) {
                           const timePart = normalized.replace(/(AM|PM)$/, '').trim();
                           const parts = timePart.split(':').map(Number);
                           let hours = parts[0] % 12;
                           if (ampmMatch[1] === 'PM') hours += 12;
                           return hours * 60 + (parts[1] || 0);
                       }
                       const parts = normalized.split(':').map(Number);
                       if (parts.length >= 2) return (parts[0] || 0) * 60 + (parts[1] || 0);
                       return 24 * 60;
                   };
                   const isDone = (c) => Boolean((c.todayNumber && c.todayNumber.value) || c.latestResult);
                   const doneItems = tickerCards.slice().filter(isDone).sort((a, b) => {
                       const aTime = a.todayNumber && a.todayNumber.declaredAt ? new Date(a.todayNumber.declaredAt).getTime() : parseMins(a.resultTime);
                       const bTime = b.todayNumber && b.todayNumber.declaredAt ? new Date(b.todayNumber.declaredAt).getTime() : parseMins(b.resultTime);
                       return bTime - aTime;
                   });
                   const upcomingItems = tickerCards.slice().filter(c => !isDone(c)).sort((a, b) => parseMins(a.resultTime) - parseMins(b.resultTime));
                   const selectedItems = doneItems.slice(0, 4).concat(upcomingItems.slice(0, 2));
                   const waitSpinnerHtml = '<span class="ticker-waiting"><span class="waiting-dots"><span class="dot dot1"></span><span class="dot dot2"></span><span class="dot dot3"></span></span><span class="waiting-text-sm">WAITING</span></span>';
                   const tickerItems = selectedItems.map(c => {
                       const name = (c.name || "").toUpperCase();
                       let statusHtml = '';
                       if (c.todayNumber && c.todayNumber.value) {
                           statusHtml = `<span class="ticker-result">${c.todayNumber.value}</span>`;
                       } else if (c.latestResult) {
                           const value = (typeof c.latestResult === 'object') ? c.latestResult.result : c.latestResult;
                           statusHtml = `<span class="ticker-result">${value}</span>`;
                       } else {
                           statusHtml = `<span class="ticker-result">WAITING</span> ${waitSpinnerHtml}`;
                       }
                       return `<span class="ticker-item"><span class="ticker-name">${name}</span> ${statusHtml}</span>`;
                   }).filter(item => item && item.trim().length > 0);
                %>
                <% if (tickerItems.length > 0) { %>
                    <div class="bg-gradient-to-br from-blue-400 to-pink-700 px-3 py-2 overflow-hidden rounded-md shadow-inner">
                        <marquee behavior="scroll" direction="left" scrollamount="4" class="text-base font-semibold text-center text-white uppercase tracking-wider">
                            <%- tickerItems.join('<span class="ticker-sep"> | </span>') %>
                        </marquee>
                    </div>
                <% } %>
            <div id="timerBox" class="py-2 text-lg font-bold text-center text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-pink-700 bg-white">June 22, 2026 3:11:11
                PM</div>

            <div class="w-full mx-auto mb-3 bg-black pb-2 overflow-hidden ">

                <% if (filteredCards.length > 0) { %>
                    <% filteredCards.forEach((card, index) => { %>
                        <div class="upcoming-game-slide flex flex-col items-center justify-center text-sm text-gray-200 transition-opacity duration-500 ease-in-out <%= index === 0 ? 'block opacity-100' : 'hidden opacity-0' %>" role="alert" data-index="<%= index %>">
                            <span class="sr-only">Info</span>
                            <div class="text-2xl font-medium text-center md:font-medium md:text-base">
                                <p class="mb-1 text-3xl font-bold text-white uppercase md:font-medium md:text-base"><%= card.name %></p>
                                <% if (card.latestResult) { %>
                                    <span class="text-3xl font-bold lead text-gray-50"><%= typeof card.latestResult === 'object' ? card.latestResult.result : card.latestResult %></span>
                                <% } else { %>
                                    <svg aria-hidden="true" class="inline text-gray-200 w-7 h-7 animate-spin fill-green-600"
                                        viewBox="0 0 100 101" fill="none" xmlns="http://www.w3.org/2000/svg">
