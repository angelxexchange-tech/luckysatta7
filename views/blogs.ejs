        /* WHITE STRIP */
        .top_white_strip {
            display: flex;
            justify-content: center;
            /* center all buttons */
            align-items: center;
            gap: 12px;
            /* space between buttons */
            padding: 12px;
            background: #fff;
        }

        /* BUTTON STYLE */
        .nav_btn {
            flex: 1;
            max-width: 200px;

            display: flex;
            /* 🔥 IMPORTANT */
            justify-content: center;
            /* center text horizontally */
            align-items: center;
            /* center text vertically */

            padding: 12px 0;
            border-radius: 30px;
            font-weight: 700;
            font-size: 16px;
            text-decoration: none;

            /* GRADIENT TEXT */
            background: linear-gradient(to right, #3b82f6, #ec4899);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;

            border: 2px solid #e5e7eb;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);

            transition: 0.3s;
        }

        /* MOBILE VIEW */
        @media (max-width: 640px) {

            .top_white_strip {
                gap: 6px;
                /* 🔥 gap for mobile */
            }

            .nav_btn {
                font-size: 12px;
                padding: 8px 0;
                border-radius: 20px;
            }
        }

        .marquee_strip {
            background: #fff;
            padding: 8px 10px;
            font-weight: 600;
            font-size: 16px;
            width: 100%;
            overflow: hidden;
        }

        /* FORCE marquee to behave */
        .marquee_strip marquee {
            display: block;
            width: 100%;
        }

        /* HOVER */
        .nav_btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
        }

        .nav_btn.active {
            background: linear-gradient(to right, #3b82f6, #ec4899);
            color: #fff;
            -webkit-text-fill-color: #fff;
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.25);
            transform: scale(1.05);
        }

        /* BLINK TEXT */
        .blink_text {
            font-size: 33px;
            font-weight: 800;
            color: #fff;
            animation: blinkGlow 1s infinite;
            letter-spacing: 2px;
        }

        @keyframes blinkGlow {
            0% {
                opacity: 1;
                text-shadow: 0 0 5px #fff, 0 0 10px #ff4da6, 0 0 20px #3b82f6;
            }

            50% {
                opacity: 0.5;
                text-shadow: none;
            }

            100% {
                opacity: 1;
                text-shadow: 0 0 5px #fff, 0 0 10px #ff4da6, 0 0 20px #3b82f6;
            }
        }

        /* BLINK ANIMATION */
        @keyframes blink {
            0% {
                opacity: 1;
            }

            50% {
                opacity: 0.3;
            }

            100% {
                opacity: 1;
            }
        }

        .blink_black {
            color: #000;
            animation: blinkBlack 1s infinite;
        }

        /* BLINK ANIMATION */
        @keyframes blinkBlack {
            0% {
                opacity: 1;
            }

            50% {
                opacity: 0.3;
            }

            100% {
                opacity: 1;
            }
        }
    </style>
