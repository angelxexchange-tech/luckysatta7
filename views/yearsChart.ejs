                            el.classList.remove('open');
                            el.querySelector('.faq_toggle').innerText = '+';
                        }
                    });

                    item.classList.toggle('open');
                    this.querySelector('.faq_toggle').innerText =
                        item.classList.contains('open') ? '−' : '+';
                });
            });
        });
    </script>
    <script>
