<section class="grid grid-cols-1 gap-2 px-4 lg:grid-cols-2">
<% allGames.forEach(game => { %>
        <div class="relative overflow-hidden md:p-6 p-4 py-12 my-6 md:my-8 text-white rounded-2xl md:rounded-3xl transition-all duration-500 group bg-gradient-to-r from-fuchsia-500 to-rose-500 shadow-[inset_-5px_-5px_20px_#c026d3,inset_5px_5px_20px_#f43f5e] shadow-xl shadow-fuchsia-500/30 border border-pink-300/30 hover:shadow-2xl hover:shadow-rose-500/40">
        <div class="absolute inset-0 overflow-hidden">
            <div class="absolute -top-20 -right-20 w-40 h-40 bg-white/10 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-1000"></div>
            <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-white/10 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-1000"></div>
            <div class="absolute inset-0 bg-gradient-to-br from-transparent via-white/5 to-transparent"></div>
