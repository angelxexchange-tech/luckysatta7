            </div>
        </div>
        <div class="container mx-auto relative z-10">
            <div class="flex flex-col items-center justify-center">
                <a class="group relative" href="/chart-<%= currentYear %>/<%= game.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '') %>-satta-result">
                    <h4 class="text-xl md:text-3xl font-bold tracking-wide text-center uppercase cursor-pointer transition-all duration-300 group-hover:scale-105">
                        <span class="relative inline-block">
                            <span class="absolute inset-0 bg-gradient-to-r from-white to-white/80 blur-xl opacity-70 group-hover:opacity-90 transition-opacity duration-300"></span>
                            <span class="relative bg-gradient-to-r from-white to-gray-200 bg-clip-text text-transparent"><%= game.name %></span>
                        </span>
                        <span class="block text-lg md:text-xl mt-2 font-semibold text-white/90">Yearly Chart <%= currentYear %></span>
                    </h4>
                    <div class="w-0 h-0.5 bg-gradient-to-r from-white via-white/50 to-white mx-auto mt-3 group-hover:w-full transition-all duration-500"></div>
                    <div class="mt-4 flex items-center justify-center space-x-2 opacity-70 group-hover:opacity-100 transition-opacity duration-300">
                        <span class="text-sm font-medium text-white/90">View Chart</span>
                        <span class="text-white animate-pulse">→</span>
                    </div>
                </a>
            </div>
        </div>
        <div class="absolute top-4 right-4 w-6 h-6 border-t-2 border-r-2 border-white/30 rounded-tr-xl"></div>
        <div class="absolute bottom-4 left-4 w-6 h-6 border-b-2 border-l-2 border-white/30 rounded-bl-xl"></div>
        <div class="absolute top-6 left-6 animate-ping w-2 h-2 bg-white/40 rounded-full"></div>
        <div class="absolute bottom-6 right-6 animate-ping w-3 h-3 bg-white/30 rounded-full delay-300"></div>
    </div>
    <% }); %>
    </section>


